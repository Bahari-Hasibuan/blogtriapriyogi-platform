export async function syncBlocks(...args: any[]): Promise<any[]> {
  try {
    const db = args.find(isClient)
    if (!db) return []

    const tenantId = args[1]
    const postId = args[2]
    const blocks = Array.isArray(args[3]) ? args[3] : []

    await runQuery(db, "delete from public.post_blocks where post_id = $1 and tenant_id = $2", [postId, tenantId])

    const saved: any[] = []

    for (let i = 0; i < blocks.length; i++) {
      const block = blocks[i] || {}

      const result = await runQuery(
        db,
        `
          insert into public.post_blocks
            (tenant_id, post_id, block_type, content, sort_order)
          values
            ($1, $2, $3, $4::jsonb, $5)
          returning *
        `,
        [
          tenantId,
          postId,
          block.block_type || block.blockType || "paragraph",
          JSON.stringify(block.content || block),
          i
        ]
      )

      if (result.rows?.[0]) saved.push(result.rows[0])
    }

    return saved
  } catch {
    return []
  }
}

export async function syncSeo(...args: any[]): Promise<any> {
  try {
    const db = args.find(isClient)
    if (!db) return null

    const tenantId = args[1]
    const postId = args[2]
    const seo = args[3] || {}

    await runQuery(
      db,
      `
        insert into public.post_seo
          (tenant_id, post_id, meta_title, meta_description, canonical_url, schema_json)
        values
          ($1, $2, $3, $4, $5, $6::jsonb)
        on conflict (post_id)
        do update set
          meta_title = excluded.meta_title,
          meta_description = excluded.meta_description,
          canonical_url = excluded.canonical_url,
          schema_json = excluded.schema_json
        returning *
      `,
      [
        tenantId,
        postId,
        seo.meta_title || seo.metaTitle || null,
        seo.meta_description || seo.metaDescription || null,
        seo.canonical_url || seo.canonicalUrl || null,
        JSON.stringify(seo.schema_json || seo.schemaJson || {})
      ]
    )

    return null
  } catch {
    return null
  }
}

export async function syncTaxonomy(...args: any[]): Promise<any> {
  try {
    const db = args.find(isClient)
    if (!db) return null

    const tenantId = args[1]
    const postId = args[2]
    const taxonomy = args[3] || {}
    const categories = Array.isArray(taxonomy.categories) ? taxonomy.categories : []
    const tags = Array.isArray(taxonomy.tags) ? taxonomy.tags : []

    return { categories, tags, tenantId, postId }
  } catch {
    return null
  }
}
