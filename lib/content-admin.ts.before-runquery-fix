    const tenantId = args[1] || null
    const actorId = args[2] || null
    const entityType = args[3] || "content"
    const entityId = args[4] || null
    const action = args[5] || "update"
    const metadata = args[6] || {}

    await runQuery(
      db,
      `
        insert into public.admin_audit_logs
          (tenant_id, actor_id, entity_type, entity_id, action, metadata)
        values
          ($1, $2, $3, $4, $5, $6::jsonb)
      `,
      [tenantId, actorId, entityType, entityId, action, JSON.stringify(metadata)]
    )
