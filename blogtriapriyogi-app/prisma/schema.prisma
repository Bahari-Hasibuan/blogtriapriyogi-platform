generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String @id @default(cuid())
  email     String @unique
  favicon   String?
}

model Domain {
  id        String @id @default(cuid())
  host      String @unique
  favicon   String?
}

model Platform {
  id        String @id @default(cuid())
  favicon   String?
}
